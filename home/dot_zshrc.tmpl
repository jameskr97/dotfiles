# vim: set ft=bash :
eval "$(fzf --zsh)"             # Activate fzf
eval "$(direnv hook zsh)"       # Activate direnv
{{- if eq .chezmoi.os "linux" }}
eval "$(keychain --eval --quiet --agents ssh)"
{{- end }}

# Prompt colors per host
{{- $hostcolor := "green" }}
{{- if eq .chezmoi.hostname "m3max" }}
{{-   $hostcolor = "cyan" }}
{{- else if eq .chezmoi.hostname "crashserver" }}
{{-   $hostcolor = "red" }}
{{- else if eq .chezmoi.hostname "fileserver" "nas" }}
{{-   $hostcolor = "yellow" }}
{{- else if eq .chezmoi.hostname "tokyo-server" }}
{{-   $hostcolor = "magenta" }}
{{- end }}

# Prompt
autoload -Uz vcs_info
abbrev_path() {
    local p=${PWD/#$HOME/\~}
    # Handle root directory
    if [[ "$p" == "/" ]]; then
        echo "/"
        return
    fi
    local parts=(${(s:/:)p})
    local result=""
    # Add leading slash for absolute paths (not ~)
    [[ "$p" == /* ]] && result="/"
    for ((i=1; i<${#parts[@]}; i++)); do
        local part="${parts[$i]}"
        if [[ "$part" == .* ]]; then
            result+="${part:0:2}/"
        else
            result+="${part:0:1}/"
        fi
    done
    result+="${parts[-1]}"
    echo "$result"
}
precmd() {
    vcs_info
    ABBREV_PWD=$(abbrev_path)
    # cmd duration
    if [[ -n $CMD_START ]]; then
        local elapsed=$(( SECONDS - CMD_START ))
        (( elapsed > 2 )) && CMD_DURATION="${elapsed}s " || CMD_DURATION=""
        unset CMD_START
    fi
}
preexec() { CMD_START=$SECONDS }
zstyle ':vcs_info:git:*' formats '%b '
setopt PROMPT_SUBST
PROMPT='%F{ {{- $hostcolor -}} }[%n@%m]%f %F{blue}${ABBREV_PWD}%f %F{8}${vcs_info_msg_0_}%f%F{red}${CMD_DURATION}%f%(?.%F{magenta}.%F{red})❯%f '

# History
setopt CORRECT                      # Attempt to correct a command when you enter it incorrectly
HISTSIZE=5000                       # How many lines of history to keep in memory
HISTFILE=~/.config/zsh_history      # Where to save history to disk
SAVEHIST=5000                       # Number of history entries to save to disk
setopt APPEND_HISTORY               # Append history to the history file (no overwriting)
setopt SHARE_HISTORY                # Share history across terminals
setopt INC_APPEND_HISTORY           # Immediately append to the history file, not just when a term is killed
setopt EXTENDED_HISTORY             # Include more information in history. (command execution time, command elapsed time, command itself)
setopt HIST_IGNORE_DUPS             # Do not write events to history that are duplicates of previous events
setopt HIST_REDUCE_BLANKS           # Remove extra blanks from each command line being added to history
setopt HIST_FIND_NO_DUPS            # When searching history don't display results already cycled through twice

# Aliases
alias ls="eza"
alias ll="eza -l"
alias la="eza -laa"
alias tree="eza --tree"

alias ..="cd .."
alias ...="cd ../.."

{{- if eq .chezmoi.os "darwin" }}
alias flushdns="sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"
{{- end }}

# Functions
bw-open() {
  if ! bw login --check > /dev/null
  then
      BW_SESSION="$(bw login --raw "$1" "$BW_PASSWORD")"
      export BW_SESSION
  fi

  if ! bw unlock --check > /dev/null
  then
      BW_SESSION="$(bw unlock --raw "$BW_PASSWORD")"
  fi
  export BW_SESSION
}

{{- if eq .chezmoi.hostname "nas" }}
snapraid_cmd=$(which snapraid)
snapraid() {
  if [[ $1 == "smart" ]]; then
      command sudo "$snapraid_cmd" smart
  else
      command snapraid "$@"
  fi
}
{{- end }}
